{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@utils/*" : ["utils/constants/*", "utils/helpers/*"],
      "@page-objects/*": ["page-objects/*"]
    }
  }
}
